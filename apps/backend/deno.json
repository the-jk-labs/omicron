{
  "tasks": {
    "dev": "deno run --watch -A src/main.ts",
    "start": "deno run -A src/main.ts",
    "db:generate": "deno run -A npm:drizzle-kit@^0.30 generate",
    "db:studio": "deno run -A npm:drizzle-kit@^0.30 studio",
    "backfill:markdown": "deno run -A scripts/backfill_markdown.ts",
    "check": "deno check src/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "hono": "jsr:@hono/hono@4.12.26",
    "hono/logger": "jsr:@hono/hono@4.12.26/logger",
    "hono/cookie": "jsr:@hono/hono@4.12.26/cookie",
    "hono/factory": "jsr:@hono/hono@4.12.26/factory",
    "@fedify/fedify": "jsr:@fedify/fedify@2.2.5",
    "@fedify/fedify/vocab": "jsr:@fedify/fedify@2.2.5/vocab",
    "drizzle-orm": "npm:drizzle-orm@0.38.4",
    "drizzle-kit": "npm:drizzle-kit@0.30.6",
    "postgres": "npm:postgres@^3.4",
    "bcryptjs": "npm:bcryptjs@^2.4",
    "zod": "npm:zod@^3.24",
    "@/": "./src/"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "dom"]
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lock": false
}
