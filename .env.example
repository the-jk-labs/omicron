# ─── Omicron environment — ALL OPTIONAL ──────────────────────────────
# You do NOT need this file. `docker compose up -d --build` works with no
# .env at all: a random Postgres password and session secret are generated
# on first boot, and the instance comes up on http://localhost:5173.
#
# Copy to .env ONLY to override a default below (e.g. set your public domain
# or real SMTP). Anything you leave out keeps its built-in default.

# ── Instance identity ──
# Public domain this instance is served from (no scheme, no trailing slash).
# Leave unset for local use; set it (or use the setup wizard) to go public.
#APP_DOMAIN=blog.example.com
# Public-facing name shown in the UI.
#PUBLIC_APP_NAME=Omicron

# ── Federation ──
# "true" enables ActivityPub (WebFinger, actor, inbox/outbox). When false, the
# instance is a standalone blog. Needs a real domain + HTTPS to be useful.
#FEDERATION_ENABLED=false

# ── Secrets (normally auto-generated — leave unset) ──
# By default the stack generates a session secret and the bundled Postgres
# password into the `secrets` volume on first boot. Override only if you must.
#   SESSION_SECRET: openssl rand -hex 32
#SESSION_SECRET=
# Bundled Postgres user/db names (the password is generated, not set here).
#POSTGRES_USER=omicron
#POSTGRES_DB=omicron
# Point at an EXTERNAL database instead of the bundled one. When set, this takes
# precedence over the generated password (use this to bring your own Postgres).
#DATABASE_URL=postgres://user:password@your-db-host:5432/omicron

# ── Redis (durability & scaling) ──
# When set, the rate limiter, Fedify's KV + message queue, and the app job queue
# are backed by Redis instead of in-process memory — so queued jobs and pending
# federation deliveries survive a restart, and multiple backend processes share
# state. The docker compose stack sets this to its bundled `redis` service
# automatically; leave it unset to run the backend against in-process memory
# (fine for local `deno task dev`), or point it at your own Redis.
#REDIS_URL=redis://redis:6379

# ── Rate limiting (on by default) ──
# Disable only behind a trusted upstream that already throttles. Values are
# per-window request budgets; leave them unless you have a reason to tune.
#RATE_LIMIT_ENABLED=true
#RL_LOGIN_MAX=15            # per-IP login attempts / 15 min
#RL_REGISTER_MAX=5          # per-IP registrations / hour
#RL_API_WRITE_MAX=120       # writes / min per signed-in user (or per IP)
#RL_INBOX_MAX=300           # federation inbox POSTs / min per source IP
#INBOX_MAX_BODY_BYTES=1000000   # reject inbox POSTs larger than this

# ── Email (password reset & verification) ──
# You normally DON'T set these — email is configured in the setup wizard / admin
# page and stored in the database (with a live "send test" to confirm it works).
# These env vars are only a fallback/default; the web settings take precedence.
# Default "console" just logs the message + link to backend stdout — no SMTP
# needed for local dev or small single-user instances. Set "smtp" for real mail.
#EMAIL_TRANSPORT=console
#EMAIL_FROM=Omicron <no-reply@localhost>
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USERNAME=
#SMTP_PASSWORD=
#SMTP_TLS=false            # implicit TLS (465); false = STARTTLS (587)
# Require email confirmation before sign-in (for closed/invite instances).
#EMAIL_VERIFICATION_REQUIRED=false

# ── Public entrypoint / HTTPS (Caddy) ──
# The bundled Caddy is the public entrypoint. It gets a Let's Encrypt cert for
# your domain automatically the first time someone visits https://your-domain —
# no certbot, no domain typed into any file. Just point a DNS A/AAAA record at
# this host. Certificates persist in the `caddy_data` volume across upgrades.
# Change only if 80/443 are already in use on the host (breaks public HTTPS).
#HTTP_PORT=80
#HTTPS_PORT=443

# ── AI-scraper protection (Anubis) ──
# A proof-of-work shield for page loads, OFF by default. There is nothing to set
# here: turn it on live from the admin panel (Admin → Security). Federation and
# the API are never challenged. The backend toggles it through Caddy's internal
# admin API; override only if you run Caddy elsewhere.
#CADDY_ADMIN_URL=http://caddy:2019

# ── Networking / storage (usually leave as-is) ──
#PORT=8000
#INTERNAL_API_URL=http://backend:8000
#UPLOADS_DIR=/data/uploads
# Where generated secrets are persisted when not supplied via env/files.
#STATE_DIR=/data/state
