# ─── Omicron environment ─────────────────────────────────────────────
# Copy to .env (`cp .env.example .env`) and adjust before `docker compose up -d`.

# ── Database ──
# Used by the backend. When running via docker compose, the host is the
# `postgres` service name. Change the password before deploying publicly.
POSTGRES_USER=omicron
POSTGRES_PASSWORD=omicron
POSTGRES_DB=omicron
DATABASE_URL=postgres://omicron:omicron@postgres:5432/omicron

# ── Instance identity ──
# The public domain this instance is served from (no scheme, no trailing slash).
# This is what other fediverse instances will use to reach you.
APP_DOMAIN=localhost:5173
# Public-facing name shown in the UI.
PUBLIC_APP_NAME=Omicron

# ── Federation ──
# Set to "true" to enable ActivityPub federation (WebFinger, actor, inbox/outbox).
# When false, the instance works as a standalone blog.
FEDERATION_ENABLED=false

# ── Security ──
# Secret used to sign/secure sessions. Generate a long random value:
#   openssl rand -hex 32
SESSION_SECRET=change-me-please-use-a-long-random-string

# ── Rate limiting ──
# Abuse throttling is on by default. Set to "false" only if a trusted upstream
# (CDN/reverse-proxy) already enforces limits. The values below are per-window
# request budgets; leave them unless you have a reason to tune.
RATE_LIMIT_ENABLED=true
# Per-IP login attempts per 15 minutes (password brute-force protection).
RL_LOGIN_MAX=15
# Per-IP registrations per hour (sign-up spam protection).
RL_REGISTER_MAX=5
# Writes (non-GET) per minute, per signed-in user or per IP if anonymous.
RL_API_WRITE_MAX=120
# Federation inbox POSTs accepted per minute, per source IP.
RL_INBOX_MAX=300
# Max federation inbox body size in bytes; larger POSTs are rejected (413).
INBOX_MAX_BODY_BYTES=1000000

# ── Email (password reset & verification) ──
# Transport for transactional mail. "console" (default) just logs the message
# and its link to the backend stdout — no SMTP needed, fine for local dev and
# small single-user instances. Set to "smtp" for real delivery.
EMAIL_TRANSPORT=console
# From address on outgoing mail. Use a mailbox you control on your domain.
EMAIL_FROM=Omicron <no-reply@localhost>
# SMTP server settings (only used when EMAIL_TRANSPORT=smtp).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Implicit TLS (port 465). Leave false to use STARTTLS on port 587.
SMTP_TLS=false
# Require new users to confirm their email before they can sign in. Turn this on
# for closed/invite instances. When false, verification mail is still sent but
# never blocks sign-in.
EMAIL_VERIFICATION_REQUIRED=false

# ── Networking (usually leave as-is for docker compose) ──
# Port the backend listens on inside its container.
PORT=8000
# How the frontend reaches the backend internally (docker service name).
INTERNAL_API_URL=http://backend:8000

# ── Uploads ──
# Directory where the backend stores user-uploaded media (avatars). In docker
# compose this maps to a persistent volume; for local `deno task dev` it
# defaults to ./uploads if unset.
UPLOADS_DIR=/data/uploads
